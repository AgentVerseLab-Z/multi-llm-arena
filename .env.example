# ===========================================
# Multi-LLM Arena - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/multi_llm_arena?schema=public

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_here

# Captcha Secret (generate a random string)
CAPTCHA_SECRET=your_captcha_secret_here

# Qwen (通义千问) / DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Zhipu (智谱 GLM)
ZHIPU_API_KEY=your_zhipu_api_key_here

# Moonshot (Kimi)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Bocha Web Search API
BOCHA_API_KEY=your_bocha_api_key_here
