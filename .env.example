# ===========================================
# Multi-LLM Arena - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/multi_llm_arena?schema=public

# 安全密钥（使用预设值即可）
JWT_SECRET=multi-llm-arena-jwt
CAPTCHA_SECRET=multi-llm-arena-captcha
